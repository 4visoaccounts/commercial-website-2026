{# ========================================================================== #}
{# :: JSON-LD structured data                                                  #}
{# :: Emitted on every page. Per-page schema (Article, Breadcrumb) appended    #}
{# :: when an entry is in scope.                                               #}
{# ========================================================================== #}

{# JSON_UNESCAPED_SLASHES (64) | JSON_UNESCAPED_UNICODE (256) | JSON_HEX_TAG (1) #}
{% set jsonFlags = 321 %}

{# ---- Organization (always) ---------------------------------------------- #}
{% set organization = {
    '@type': 'Organization',
    '@id': siteUrl ~ '#organization',
    'name': siteName,
    'url': siteUrl,
    'logo': {
        '@type': 'ImageObject',
        'url': siteUrl ~ 'assets/favicon/android-icon-192x192.png',
        'width': 192,
        'height': 192
    },
    'address': {
        '@type': 'PostalAddress',
        'streetAddress': 'Galileilaan 15',
        'addressLocality': 'Niel',
        'postalCode': '2845',
        'addressCountry': 'BE'
    }
} %}

<script type="application/ld+json">
{{ {
    '@context': 'https://schema.org',
    '@graph': [organization]
}|json_encode(jsonFlags)|raw }}
</script>

{# ---- WebSite (home only) ------------------------------------------------- #}
{% set isHome = craft.app.request.pathInfo == '' %}
{% if isHome %}
    <script type="application/ld+json">
    {{ {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        '@id': siteUrl ~ '#website',
        'url': siteUrl,
        'name': siteName,
        'publisher': { '@id': siteUrl ~ '#organization' }
    }|json_encode(jsonFlags)|raw }}
    </script>
{% endif %}

{# ---- NewsArticle (news entries) ----------------------------------------- #}
{% if entry is defined and entry and entry.section is defined and entry.section.handle == 'news' %}
    {% set articleImage = entry.commonAsset.one() ?? null %}
    {% set articleHeadline = (entry.commonTitle ?? entry.title)|striptags %}

    {# Description fallback chain: SEO field → first wysiwyg block → empty #}
    {% set articleDescription = '' %}
    {% if entry.seo is defined and (entry.seo.description ?? '') %}
        {% set articleDescription = entry.seo.description %}
    {% else %}
        {% set wysiwyg = entry.commonWysiwyg ?? null %}
        {% if wysiwyg %}
            {% for block in wysiwyg.all() %}
                {% if loop.first and block.type.handle == 'commonWysiwygBlock' %}
                    {% set articleDescription = block.commonDescription|striptags|slice(0, 200) %}
                {% endif %}
            {% endfor %}
        {% endif %}
    {% endif %}

    {% set newsArticle = {
        '@context': 'https://schema.org',
        '@type': 'NewsArticle',
        'mainEntityOfPage': { '@type': 'WebPage', '@id': entry.url },
        'headline': articleHeadline,
        'description': articleDescription,
        'datePublished': entry.postDate|atom,
        'dateModified': entry.dateUpdated|atom,
        'author': { '@id': siteUrl ~ '#organization' },
        'publisher': { '@id': siteUrl ~ '#organization' }
    } %}
    {% if articleImage %}
        {% set newsArticle = newsArticle|merge({
            'image': [articleImage.getUrl({ width: 1200, format: 'webp', quality: 85 })]
        }) %}
    {% endif %}

    <script type="application/ld+json">
    {{ newsArticle|json_encode(jsonFlags)|raw }}
    </script>
{% endif %}

{# ---- BreadcrumbList (any non-home page) --------------------------------- #}
{% if entry is defined and entry and not isHome %}
    {% set crumbs = [{
        '@type': 'ListItem',
        'position': 1,
        'name': 'Home',
        'item': siteUrl
    }] %}

    {% if entry.section is defined and entry.section.handle == 'news' %}
        {% set crumbs = crumbs|merge([{
            '@type': 'ListItem',
            'position': 2,
            'name': 'News',
            'item': siteUrl ~ 'news'
        }, {
            '@type': 'ListItem',
            'position': 3,
            'name': (entry.commonTitle ?? entry.title)|striptags,
            'item': entry.url
        }]) %}
    {% else %}
        {% set crumbs = crumbs|merge([{
            '@type': 'ListItem',
            'position': 2,
            'name': (entry.commonTitle ?? entry.title)|striptags,
            'item': entry.url
        }]) %}
    {% endif %}

    <script type="application/ld+json">
    {{ {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        'itemListElement': crumbs
    }|json_encode(jsonFlags)|raw }}
    </script>
{% endif %}
