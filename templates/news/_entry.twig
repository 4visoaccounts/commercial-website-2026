{# ========================================================================== #}
{# :: News Entry Detail                                                        #}
{# :: Entry type: newsBody                                                     #}
{# ========================================================================== #}
{% extends "_layouts/base.twig" %}

{% block content %}

{# ========================================================================== #}
{# :: Variables                                                                 #}
{# ========================================================================== #}
{% set image = entry.commonAsset.one() ?? null %}

{# ========================================================================== #}
{# :: Hero — image card inside container, animated gradient bg behind        #}
{# ========================================================================== #}
<article>
<header class="text-white relative z-10 pt-24 md:pt-40">
    {# Green gradient bg — stops 180px short of the section bottom so the image card overflows onto the white below #}
    <div class="absolute inset-x-0 top-0 bg-cover bg-center bg-no-repeat" style="bottom: 180px; background-image: url('/assets/gradient.png');"></div>

    {# Animated logo grid with supply-chain transport animation #}
    <div
        x-data="{
            segments1: [], segId1: 0, segOpacity1: 1, activeLogos1: [],
            segments2: [], segId2: 0, segOpacity2: 1, activeLogos2: [],
            cols: 0,
            logoArray: [],
            _startJourney2: false,
            _gen: 0,
            lineGeom(from, to) {
                const c = this.$el.getBoundingClientRect();
                const f = from.getBoundingClientRect();
                const t = to.getBoundingClientRect();
                const fx = f.left + f.width/2 - c.left, fy = f.top + f.height/2 - c.top;
                const tx = t.left + t.width/2 - c.left, ty = t.top + t.height/2 - c.top;
                return {
                    x: fx, y: fy,
                    len: Math.sqrt((tx-fx)**2+(ty-fy)**2).toFixed(1),
                    angle: (Math.atan2(ty-fy, tx-fx)*180/Math.PI).toFixed(2)
                };
            },
            buildPath(a, b, all) {
                const cols = this.cols;
                const aRow = Math.floor(a/cols), aCol = a%cols;
                const bRow = Math.floor(b/cols), bCol = b%cols;
                const dr = bRow >= aRow ? 1 : -1, dc = bCol >= aCol ? 1 : -1;
                const path = [a];
                if (Math.random() < 0.5) {
                    for (let col=aCol+dc; col*dc<=bCol*dc; col+=dc) { const i=aRow*cols+col; if(i>=0&&i<all.length) path.push(i); }
                    for (let row=aRow+dr; row*dr<=bRow*dr; row+=dr) { const i=row*cols+bCol; if(i>=0&&i<all.length) path.push(i); }
                } else {
                    for (let row=aRow+dr; row*dr<=bRow*dr; row+=dr) { const i=row*cols+aCol; if(i>=0&&i<all.length) path.push(i); }
                    for (let col=aCol+dc; col*dc<=bCol*dc; col+=dc) { const i=bRow*cols+col; if(i>=0&&i<all.length) path.push(i); }
                }
                if (path[path.length-1] !== b) path.push(b);
                return path.map(i => all[i]).filter(Boolean);
            },
            async _doJourney(slot, gen) {
                if (this._gen !== gen) return;
                const aKey = `activeLogos${slot}`, sKey = `segments${slot}`, oKey = `segOpacity${slot}`, iKey = `segId${slot}`;
                this[aKey].forEach(el => el.classList.remove('hero-logo-active','hero-logo-transit','hero-logo-visited'));
                this[aKey] = [];
                this[sKey] = [];
                this[oKey] = 1;
                const all = this.$el.querySelectorAll('.hero-logo');
                if (!all.length) return;
                const contentEl = this.$el.parentElement.querySelector('.container');
                const cRect = contentEl ? contentEl.getBoundingClientRect() : null;
                const allArr = Array.from(all);
                const safe = cRect
                    ? allArr.filter(el => {
                          const r = el.getBoundingClientRect();
                          return r.right < cRect.left || r.left > cRect.right ||
                                 r.bottom < cRect.top || r.top > cRect.bottom;
                      })
                    : allArr;
                if (safe.length < 2) { await new Promise(r=>setTimeout(r,1000)); return; }
                let a, b, attempts = 0;
                do {
                    a = Math.floor(Math.random()*safe.length);
                    b = Math.floor(Math.random()*safe.length);
                    const aIdx = allArr.indexOf(safe[a]);
                    const bIdx = allArr.indexOf(safe[b]);
                    const dist = Math.abs(Math.floor(aIdx/this.cols)-Math.floor(bIdx/this.cols))
                               + Math.abs((aIdx%this.cols)-(bIdx%this.cols));
                    if (dist>=8 && dist<=18) break;
                } while (++attempts < 200);
                const path = this.buildPath(allArr.indexOf(safe[a]), allArr.indexOf(safe[b]), all);
                if (path.length < 2) { await new Promise(r=>setTimeout(r,1000)); return; }
                this[aKey] = path;
                path[0].classList.add('hero-logo-active');
                path[path.length-1].classList.add('hero-logo-active');
                await new Promise(r => setTimeout(r, 500));
                for (let i = 0; i < path.length-1; i++) {
                    if (this._gen !== gen) return;
                    const isLastHop = i === path.length-2;
                    if (!isLastHop) path[i+1].classList.add('hero-logo-transit');
                    const geom = this.lineGeom(path[i], path[i+1]);
                    this[sKey].push({...geom, id: ++this[iKey]});
                    await new Promise(r => setTimeout(r, 500));
                    if (i > 0) { path[i].classList.remove('hero-logo-active','hero-logo-transit'); path[i].classList.add('hero-logo-visited'); }
                    if (!isLastHop) {
                        path[i+1].classList.remove('hero-logo-transit');
                        path[i+1].classList.add('hero-logo-active');
                    }
                }
                await new Promise(r => setTimeout(r, 1500));
                if (slot === 1) this._startJourney2 = true;
                this[oKey] = 0;
                path.forEach(el => el.classList.remove('hero-logo-active','hero-logo-visited'));
                await new Promise(r => setTimeout(r, 1000));
                this[sKey] = [];
                this[oKey] = 1;
                await new Promise(r => setTimeout(r, 400));
            },
            _launch() {
                const rect = this.$el.getBoundingClientRect();
                const cell = 40;
                const pad  = 48;
                const cols = Math.floor((rect.width  - pad + 32) / cell);
                const rows = Math.ceil( (rect.height - pad + 32) / cell) + 1;
                this.cols = cols;
                this.logoArray = Array.from({length: cols * rows}, (_, i) => i);
                this._startJourney2 = false;
                const gen = ++this._gen;
                if (window.innerWidth < 768) return;
                (async () => {
                    await new Promise(r => setTimeout(r, 1000));
                    while (this._gen === gen) { await this._doJourney(1, gen); }
                })();
                (async () => {
                    await new Promise(r => { const chk = () => (this._startJourney2 || this._gen !== gen) ? r() : setTimeout(chk, 50); chk(); });
                    while (this._gen === gen) { await this._doJourney(2, gen); }
                })();
            },
            init() {
                this.$nextTick(() => this._launch());
                let resizeTimer;
                window.addEventListener('resize', () => {
                    clearTimeout(resizeTimer);
                    resizeTimer = setTimeout(() => {
                        this.segments1 = []; this.segments2 = [];
                        this.segOpacity1 = 1; this.segOpacity2 = 1;
                        this._launch();
                        setTimeout(() => {
                            this.$el.querySelectorAll('.hero-logo').forEach(el =>
                                el.classList.remove('hero-logo-active','hero-logo-transit','hero-logo-visited'));
                            this.activeLogos1 = []; this.activeLogos2 = [];
                        }, 150);
                    }, 300);
                });
            }
        }"
        class="absolute inset-x-0 top-0 overflow-hidden pointer-events-none"
        style="bottom: 180px;"
    >
        <div class="absolute inset-0 flex flex-wrap content-start gap-8 p-6">
            <template x-for="i in logoArray" :key="i">
                <div class="hero-logo w-2 h-2 shrink-0">
                    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 98 99" fill="none">
                        <path d="M68.2923 0.0463867C62.8741 0.0463867 57.8018 1.5018 53.4326 4.03146C62.3092 9.17162 68.2923 18.7704 68.2923 29.7669C68.2923 40.7634 62.3092 50.3622 53.4326 55.5024C57.8018 58.0321 62.8741 59.4875 68.2923 59.4875C84.6967 59.4875 98.0001 46.1808 98.0001 29.7669C98.0001 13.3531 84.6967 0.0463867 68.2923 0.0463867Z" fill="#288760"/>
                        <path d="M29.742 38.7302C35.1602 38.7302 40.2325 40.1856 44.6016 42.7153C35.725 47.8555 29.742 57.4543 29.742 68.4508C29.742 79.4473 35.725 89.0461 44.6016 94.1862C40.2325 96.7159 35.1602 98.1713 29.742 98.1713C13.3376 98.1829 0.0341797 84.8646 0.0341797 68.4508C0.0341797 52.0369 13.3376 38.7302 29.742 38.7302Z" fill="#288760"/>
                        <path d="M97.9997 68.4508C97.9997 63.0334 96.5472 57.9625 94.011 53.5847C88.8695 62.4674 79.2781 68.4508 68.2804 68.4508C57.2826 68.4508 47.6913 62.4674 42.5497 53.5847C40.0251 57.9625 38.561 63.0334 38.561 68.4508C38.561 84.8646 51.8644 98.1713 68.2688 98.1713C84.6733 98.1713 97.9766 84.8646 97.9766 68.4508H97.9997Z" fill="#288760"/>
                        <path d="M59.4387 29.7205C59.4387 35.1379 57.9861 40.2088 55.4499 44.5866C50.3084 35.7039 40.7171 29.7205 29.7193 29.7205C18.7216 29.7205 9.13022 35.7039 3.98871 44.5866C1.46406 40.2088 0 35.1379 0 29.7205C0.0115281 13.3067 13.3149 0 29.7193 0C46.1238 0 59.4271 13.3067 59.4271 29.7205H59.4387Z" fill="#288760"/>
                    </svg>
                </div>
            </template>
        </div>

        <div :style="`opacity: ${segOpacity1}; transition: opacity 1s ease;`" class="absolute inset-0 pointer-events-none">
            <template x-for="seg in segments1" :key="seg.id">
                <div
                    class="hero-connection-seg absolute pointer-events-none"
                    :style="`left:${seg.x}px; top:${seg.y}px; width:${seg.len}px; transform:rotate(${seg.angle}deg);`"
                ></div>
            </template>
        </div>
        <div :style="`opacity: ${segOpacity2}; transition: opacity 1s ease;`" class="absolute inset-0 pointer-events-none">
            <template x-for="seg in segments2" :key="seg.id">
                <div
                    class="hero-connection-seg absolute pointer-events-none"
                    :style="`left:${seg.x}px; top:${seg.y}px; width:${seg.len}px; transform:rotate(${seg.angle}deg);`"
                ></div>
            </template>
        </div>
    </div>

    <style>
        .hero-logo { opacity: 0.3; transition: opacity 0.6s ease, transform 0.6s ease, filter 0.6s ease; }
        .hero-logo-active { opacity: 0.35; transform: scale(1.3); filter: brightness(0) invert(1); }
        .hero-logo-transit { opacity: 0.25; transform: scale(1.3); filter: brightness(0) invert(1); }
        .hero-logo-visited { opacity: 0.3; filter: brightness(0) invert(1); }
        .hero-connection-seg { height: 2px; transform-origin: 0 50%; background: repeating-linear-gradient(90deg, rgba(255,255,255,0.3) 0, rgba(255,255,255,0.3) 6px, transparent 6px, transparent 10px); }
    </style>

    {# Image card constrained to container, overlapping white section below #}
    <div class="container mx-auto px-4 lg:px-8 relative z-10">
        <div class="relative w-full overflow-hidden rounded-xl bg-primary-pine animate-fade-up"
            style="min-height: 50vh; margin-bottom: -180px;">

            {# Hero image — direct <img> for reliable absolute positioning (component's <picture> wrapper interferes) #}
            {% if image %}
                <img
                    src="{{ image.getUrl({ width: 1600, format: 'webp', quality: 80 }) }}"
                    srcset="{{ image.getUrl({ width: 800, format: 'webp', quality: 80 }) }} 800w, {{ image.getUrl({ width: 1200, format: 'webp', quality: 80 }) }} 1200w, {{ image.getUrl({ width: 1600, format: 'webp', quality: 80 }) }} 1600w"
                    sizes="100vw"
                    alt="{{ (entry.commonTitle ?? entry.title)|striptags }}"
                    class="absolute inset-0 w-full h-full object-cover object-center"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                >
            {% endif %}

            {# Gradient overlay #}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

            {# Title + date pinned to bottom #}
            <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
                <div class="max-w-3xl">
                    {% if entry.postDate %}
                        <time datetime="{{ entry.postDate|atom }}" class="block text-xs font-medium text-white/70 uppercase tracking-widest mb-3 animate-fade-up [animation-delay:100ms]">
                            {{ entry.postDate|date('M j, Y') }}
                        </time>
                    {% endif %}
                    {% if entry.commonTitle %}
                        <h1 class="text-white animate-fade-up [animation-delay:200ms]">
                            {{ entry.commonTitle|striptags|raw }}
                        </h1>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</header>

{# ========================================================================== #}
{# :: Article Body                                                              #}
{# ========================================================================== #}
<div
    x-data="{ visible: false }"
    x-intersect.once.margin.0px.0px.-100px.0px="visible = true"
    class="bg-white">

    <div class="container mx-auto px-4 lg:px-8 pb-16 md:pb-24" style="padding-top: clamp(13rem, 16vw, 15rem);">
        <div class="max-w-3xl mx-auto">

            {# Back link #}
            <div class="mb-10 md:mb-14"
                style="opacity: 0; transform: translateY(40px);"
                :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s ease-out, transform 0.5s ease-out;`">
                <a href="/news" class="inline-flex items-center gap-2 text-[15px] font-medium text-primary hover:text-primary-pine no-underline transition-colors">
                    <i class="ph ph-arrow-left"></i>
                    Back to news
                </a>
            </div>

            {# Wysiwyg blocks #}
            {% if entry.commonWysiwyg is defined %}
                {% for block in entry.commonWysiwyg.all() %}

                    {# Rich text #}
                    {% if block.type.handle == 'commonWysiwygBlock' %}
                        <div class="s-wysiwyg text-dark text-[18px] leading-relaxed font-light mb-16"
                            style="opacity: 0; transform: translateY(40px);"
                            :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s 150ms ease-out, transform 0.5s 150ms ease-out;`">
                            {{ block.commonDescription|raw }}
                        </div>

                    {# CTA button #}
                    {% elseif block.type.handle == 'commonWysiwygCta' %}
                        {% set ctaEntry = block.commonCta.one() ?? null %}
                        {% if ctaEntry %}
                            {% set ctaLink = ctaEntry.commonLink ?? null %}
                            {% if ctaLink %}
                                <div class="mb-16 text-center"
                                    style="opacity: 0; transform: translateY(40px);"
                                    :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s 150ms ease-out, transform 0.5s 150ms ease-out;`">
                                    {% include 'components/button' with {
                                        href: ctaLink.url ?? '#',
                                        text: ctaLink.text ?? '',
                                        variant: 'primary',
                                    } %}
                                </div>
                            {% endif %}
                        {% endif %}

                    {# Image block #}
                    {% elseif block.type.handle == 'commonImageBlock' %}
                        {% set blockImage = block.commonAsset.one() ?? null %}
                        {% set caption = block.commonTitle ?? null %}
                        {% if blockImage %}
                            <figure class="mb-16"
                                style="opacity: 0; transform: translateY(40px);"
                                :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s 150ms ease-out, transform 0.5s 150ms ease-out;`">
                                <div class="rounded overflow-hidden">
                                    {% include 'components/image' with {
                                        asset: blockImage,
                                        class: 'w-full',
                                        sizes: '(max-width: 768px) 100vw, 48rem',
                                        widths: [600, 900, 1200],
                                    } %}
                                </div>
                                {% if caption %}
                                    <figcaption class="mt-3 text-sm text-grey text-center">
                                        {{ caption|striptags }}
                                    </figcaption>
                                {% endif %}
                            </figure>
                        {% endif %}

                    {% endif %}
                {% endfor %}
            {% endif %}

        </div>
    </div>
</div>

{# ========================================================================== #}
{# :: Related news                                                              #}
{# ========================================================================== #}
{% set related = craft.entries()
    .section('news')
    .id(['not', entry.id])
    .orderBy('postDate desc')
    .limit(3)
    .all() %}

{% if related|length %}
    <footer class="bg-white pb-16 md:pb-24">
        <div class="container mx-auto px-4 lg:px-8">
            <div class="max-w-5xl mx-auto">
                <h2 class="mb-8 text-dark">Related news</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    {% for item in related %}
                        {% set itemImage = item.commonAsset.one() ?? null %}
                        <a href="{{ item.url }}"
                            class="block relative aspect-[4/3] rounded-xl overflow-hidden group no-underline hover:-translate-y-1 transition-transform duration-300">
                            {% if itemImage %}
                                <img
                                    src="{{ itemImage.getUrl({ width: 900, format: 'webp', quality: 80 }) }}"
                                    srcset="{{ itemImage.getUrl({ width: 400, format: 'webp', quality: 80 }) }} 400w, {{ itemImage.getUrl({ width: 600, format: 'webp', quality: 80 }) }} 600w, {{ itemImage.getUrl({ width: 900, format: 'webp', quality: 80 }) }} 900w"
                                    sizes="(max-width: 768px) 100vw, 33vw"
                                    alt="{{ (item.commonTitle ?? item.title)|striptags }}"
                                    class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
                                    loading="lazy"
                                    decoding="async"
                                >
                            {% endif %}
                            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                            <div class="absolute bottom-0 left-0 right-0 p-6">
                                {% if item.postDate %}
                                    <time datetime="{{ item.postDate|atom }}" class="text-xs font-medium text-white/70 uppercase tracking-widest block mb-2">
                                        {{ item.postDate|date('M j, Y') }}
                                    </time>
                                {% endif %}
                                <h3 class="text-white font-semibold leading-snug text-lg">{{ (item.commonTitle ?? item.title)|striptags }}</h3>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    </footer>
{% endif %}

</article>

{% endblock %}
