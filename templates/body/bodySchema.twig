{# ========================================================================== #}
{# :: Variables #}
{# ========================================================================== #}
{% set id = data.commonId ?? "" %}
{% set title = data.commonTitle ?? "" %}
{% set description = data.commonDescription ?? "" %}
{% set link = data.commonLink ?? null %}
{% set schemaBlocks = craft.entries.section('schemaBlock').all() %}
{% set spacing = data.commonSpacing ?? "default" %}
{% if spacing == "small" %}
    {% set spacingClass = "py-8 md:py-16" %}
{% elseif spacing == "smallTopDefaultBottom" %}
    {% set spacingClass = "pt-8 md:pt-16 pb-16 md:pb-32" %}
{% elseif spacing == "smallBottomDefaultTop" %}
    {% set spacingClass = "pt-16 md:pt-32 pb-8 md:pb-16" %}
{% else %}
    {% set spacingClass = "py-16 md:py-32" %}
{% endif %}

{# ========================================================================== #}
{# :: Styles #}
{# ========================================================================== #}
<style>
@keyframes schema-logo-travel {
    from { offset-distance: 0%; }
    to   { offset-distance: 100%; }
}
.schema-logo-travel {
    position: absolute;
    width: 0;
    height: 0;
    overflow: visible;
    offset-path: path('M 300,20 A 190,190 0 0 1 490,210 A 190,190 0 0 1 300,400 A 190,190 0 0 1 110,210 A 190,190 0 0 1 300,20');
    offset-distance: 0%;
    offset-rotate: 0deg;
    animation: schema-logo-travel 90s linear infinite;
    pointer-events: none;
}
.schema-logo-travel-2 { animation-delay: -30s; }
.schema-logo-travel-3 { animation-delay: -60s; }
.schema-center-wrapper { display: contents; }
</style>

{# ========================================================================== #}
{# :: Component #}
{# ========================================================================== #}
<section x-data="{ visible: false }" x-intersect.once.margin.0px.0px.-100px.0px="visible = true" class="container mx-auto px-4 lg:px-8 {{ spacingClass }} relative" id="{{id}}">
    {# Background vertical lines #}
    <div class="absolute inset-y-0 left-[10%] w-4/5 flex flex-row justify-between pointer-events-none">
        {% for i in 1..6 %}
            <div class="h-full w-px bg-schema-line"></div>
        {% endfor %}
    </div>
    <div class="bg-schema-bg rounded p-8 md:p-16 md:py-28 relative overflow-hidden">

        {# Content #}
        <div class="relative z-10 text-center space-y-8">
            {% if title %}
                <h2 style="opacity: 0; transform: translateY(40px);" :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s ease-out, transform 0.5s ease-out;`">{{ title|striptags|raw }}</h2>
            {% endif %}

            {# Schema diagram #}
            {% if schemaBlocks|length >= 4 %}

                {# Mobile layout: 2×2 card grid with hub connector #}
                <div class="md:hidden"
                    style="opacity: 0; transform: translateY(40px);"
                    :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s 150ms ease-out, transform 0.5s 150ms ease-out;`">
                    <div class="flex flex-col gap-3">
                        {# Top row: modules 0 + 1 #}
                        <div class="grid grid-cols-2 gap-3">
                            {% for block in schemaBlocks|slice(0, 2) %}
                                <div class="bg-schema-bg border-2 border-primary rounded-xl p-3 flex flex-col gap-2 text-left">
                                    <div class="font-bold text-dark text-sm leading-tight">{{ block.commonTitle|striptags }}</div>
                                    <div class="flex flex-col gap-1.5 items-start">
                                        {% for subBlock in block.commonBlocks.all() %}
                                            <span class="inline-block bg-peach rounded-full px-2 py-0.5 text-xs font-medium text-dark leading-snug">{{ subBlock.commonTitle|striptags|raw }}</span>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        {# Center logo #}
                        <div class="flex justify-center items-center py-1">
                            {% include "/logos/logo-green.twig" with { customClass: 'h-8' } %}
                        </div>
                        {# Bottom row: modules 2 + 3 #}
                        <div class="grid grid-cols-2 gap-3">
                            {% for block in schemaBlocks|slice(2, 2) %}
                                <div class="bg-schema-bg border-2 border-primary rounded-xl p-3 flex flex-col gap-2 text-left">
                                    <div class="font-bold text-dark text-sm leading-tight">{{ block.commonTitle|striptags }}</div>
                                    <div class="flex flex-col gap-1.5 items-start">
                                        {% for subBlock in block.commonBlocks.all() %}
                                            <span class="inline-block bg-peach rounded-full px-2 py-0.5 text-xs font-medium text-dark leading-snug">{{ subBlock.commonTitle|striptags|raw }}</span>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# Desktop layout: circle diagram #}
                <div class="hidden md:block md:overflow-x-auto"
                    style="opacity: 0; transform: translateY(40px);"
                    :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s 150ms ease-out, transform 0.5s 150ms ease-out;`">
                    <div class="relative md:min-w-[1000px] py-4 md:py-16">
                        {# Flex layout: left pills | circle diagram | right pills #}
                        <div class="flex flex-row justify-center">

                            {# Left pill column (schemaBlocks[0] top, schemaBlocks[2] bottom) #}
                            <div class="hidden md:block relative flex-shrink-0" style="width: 200px; height: 420px;">
                                {# Top-left pills (schemaBlocks[0]) centered around y=80px #}
                                <div class="absolute flex flex-col items-end justify-center" style="top: 0; height: 152px; left: 0; right: 0;">
                                    <div class="relative flex flex-col gap-2 items-end">
                                        <div class="absolute right-0 top-[14px] bottom-[14px] border-r-2 border-dashed border-primary-dotted-line pointer-events-none"></div>
                                        {% for block in schemaBlocks[0].commonBlocks.all() %}
                                            <div class="flex items-center">
                                                <span class="inline-block rounded-full px-3 py-1.5 text-sm font-medium text-dark whitespace-nowrap bg-peach">{{ block.commonTitle|striptags|raw }}</span>
                                                <div class="w-6 shrink-0 border-t-2 border-dashed border-primary-dotted-line"></div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {# Bottom-left pills (schemaBlocks[2]) centered around y=300px #}
                                <div class="absolute flex flex-col items-end justify-center" style="top: 268px; height: 152px; left: 0; right: 0;">
                                    <div class="relative flex flex-col gap-2 items-end">
                                        <div class="absolute right-0 top-[14px] bottom-[14px] border-r-2 border-dashed border-primary-dotted-line pointer-events-none"></div>
                                        {% for block in schemaBlocks[2].commonBlocks.all() %}
                                            <div class="flex items-center">
                                                <span class="inline-block rounded-full px-3 py-1.5 text-sm font-medium text-dark whitespace-nowrap bg-peach">{{ block.commonTitle|striptags|raw }}</span>
                                                <div class="w-6 shrink-0 border-t-2 border-dashed border-primary-dotted-line"></div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>

                            {# Center: dashed circle + 4 module cards + logo #}
                            <div class="schema-center-wrapper">
                            <div class="schema-center-inner relative flex-shrink-0" style="width: 600px; height: 420px;">
                                {# Dashed circle SVG with clockwise arrowheads at cardinal points #}
                                <svg viewBox="0 0 600 420" fill="none" class="absolute inset-0 w-full h-full pointer-events-none text-primary-dotted-line">
                                    <circle cx="300" cy="210" r="190" stroke="currentColor" stroke-width="2" stroke-dasharray="8 5"/>
                                </svg>
                                {# 3 logos traveling along the circle path, evenly spaced 120° apart #}
                                <div class="schema-logo-travel">
                                    <div style="position: absolute; transform: translate(-50%, -50%);">
                                        {% include "/shapes/logo.twig" with { customClass: 'w-5 h-5' } %}
                                    </div>
                                </div>
                                <div class="schema-logo-travel schema-logo-travel-2">
                                    <div style="position: absolute; transform: translate(-50%, -50%);">
                                        {% include "/shapes/logo.twig" with { customClass: 'w-5 h-5' } %}
                                    </div>
                                </div>
                                <div class="schema-logo-travel schema-logo-travel-3">
                                    <div style="position: absolute; transform: translate(-50%, -50%);">
                                        {% include "/shapes/logo.twig" with { customClass: 'w-5 h-5' } %}
                                    </div>
                                </div>
                                {# Connector lines: left edge → TL/BL cards #}
                                <div class="hidden md:block absolute border-t-2 border-dashed border-primary-dotted-line pointer-events-none" style="left: 0; width: 100px; top: 76px;"></div>
                                <div class="hidden md:block absolute border-t-2 border-dashed border-primary-dotted-line pointer-events-none" style="left: 0; width: 100px; top: 344px;"></div>
                                {# Connector lines: TR/BR cards → right edge #}
                                <div class="hidden md:block absolute border-t-2 border-dashed border-primary-dotted-line pointer-events-none" style="right: 0; width: 100px; top: 76px;"></div>
                                <div class="hidden md:block absolute border-t-2 border-dashed border-primary-dotted-line pointer-events-none" style="right: 0; width: 100px; top: 344px;"></div>
                                {# TL module card: schemaBlocks[0] at (166, 76) #}
                                <div class="absolute inline-flex border-primary border-2 bg-schema-bg rounded-full px-6 py-3 font-bold text-dark whitespace-nowrap text-md" style="left: 166px; top: 76px; transform: translate(-50%, -50%);">
                                    {{ schemaBlocks[0].commonTitle|striptags }}
                                </div>
                                {# TR module card: schemaBlocks[1] at (434, 76) #}
                                <div class="absolute inline-flex border-primary border-2 bg-schema-bg rounded-full px-6 py-3 font-bold text-dark whitespace-nowrap text-md" style="left: 434px; top: 76px; transform: translate(-50%, -50%);">
                                    {{ schemaBlocks[1].commonTitle|striptags }}
                                </div>
                                {# BL module card: schemaBlocks[2] at (166, 344) #}
                                <div class="absolute inline-flex border-primary border-2 bg-schema-bg rounded-full px-6 py-3 font-bold text-dark whitespace-nowrap text-md" style="left: 166px; top: 344px; transform: translate(-50%, -50%);">
                                    {{ schemaBlocks[2].commonTitle|striptags }}
                                </div>
                                {# BR module card: schemaBlocks[3] at (434, 344) #}
                                <div class="absolute inline-flex border-primary border-2 bg-schema-bg rounded-full px-6 py-3 font-bold text-dark whitespace-nowrap text-md" style="left: 434px; top: 344px; transform: translate(-50%, -50%);">
                                    {{ schemaBlocks[3].commonTitle|striptags }}
                                </div>
                                {# Center logo #}
                                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
                                    {% include "/logos/logo-green.twig" with { customClass: 'h-10' } %}
                                </div>
                            </div>
                            </div>{# end schema-center-wrapper #}

                            {# Right pill column (schemaBlocks[1] top, schemaBlocks[3] bottom) #}
                            <div class="hidden md:block relative flex-shrink-0" style="width: 200px; height: 420px;">
                                {# Top-right pills (schemaBlocks[1]) centered around y=80px #}
                                <div class="absolute flex flex-col items-start justify-center" style="top: 0; height: 152px; left: 0; right: 0;">
                                    <div class="relative flex flex-col gap-2 items-start">
                                        <div class="absolute left-0 top-[14px] bottom-[14px] border-l-2 border-dashed border-primary-dotted-line pointer-events-none"></div>
                                        {% for block in schemaBlocks[1].commonBlocks.all() %}
                                            <div class="flex items-center">
                                                <div class="w-6 shrink-0 border-t-2 border-dashed border-primary-dotted-line"></div>
                                                <span class="inline-block bg-peach rounded-full px-3 py-1.5 text-sm font-medium text-dark whitespace-nowrap">{{ block.commonTitle|striptags|raw }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {# Bottom-right pills (schemaBlocks[3]) centered around y=300px #}
                                <div class="absolute flex flex-col items-start justify-center" style="top: 268px; height: 152px; left: 0; right: 0;">
                                    <div class="relative flex flex-col gap-2 items-start">
                                        <div class="absolute left-0 top-[14px] bottom-[14px] border-l-2 border-dashed border-primary-dotted-line pointer-events-none"></div>
                                        {% for block in schemaBlocks[3].commonBlocks.all() %}
                                            <div class="flex items-center">
                                                <div class="w-6 shrink-0 border-t-2 border-dashed border-primary-dotted-line"></div>
                                                <span class="inline-block bg-peach rounded-full px-3 py-1.5 text-sm font-medium text-dark whitespace-nowrap">{{ block.commonTitle|striptags|raw }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            {% endif %}

            {% if description %}
                <h5 class="mx-auto"
                    style="opacity: 0; transform: translateY(40px);"
                    :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s 300ms ease-out, transform 0.5s 300ms ease-out;`">{{ description|striptags('<strong><br><br/>')|raw }}</h5>
            {% endif %}

            {% if link %}
                <div style="opacity: 0; transform: translateY(40px);" :style="`opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : 40}px); transition: opacity 0.5s 400ms ease-out, transform 0.5s 400ms ease-out;`">
                    {% include 'components/button' with {
                        href: link.url ?? '#',
                        text: link.text ?? 'Request a Demo',
                        variant: 'primary',
                    } %}
                </div>
            {% endif %}
        </div>
    </div>
</section>
